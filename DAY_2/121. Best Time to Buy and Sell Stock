class Solution {
    static int solveBU(int[] arr) {
    int n = arr.length;

    int[][] dp = new int[n + 1][3];

    // dp[n][*] = 0 already (base case)

    for (int i = n - 1; i >= 0; i--) {
        for (int count = 0; count <= 1; count++) {

            if (count == 0) {
                int take = -arr[i] + dp[i + 1][count + 1];
                int skip = dp[i + 1][count];
                dp[i][count] = Math.max(take, skip);
            } else {
                int take = arr[i] + dp[i + 1][count + 1];
                int skip = dp[i + 1][count];
                dp[i][count] = Math.max(take, skip);
            }
        }
    }

    return dp[0][0];
}

    public int maxProfit(int[] prices) {
        int n=prices.length;
        int max=0;
        int ans=0;
        for(int i=n-1;i>=0;i--){
max=Math.max(max,prices[i]);
ans=Math.max(ans,max-prices[i]);
        }
        // return ans;
        return solveBU(prices);
    }
}
